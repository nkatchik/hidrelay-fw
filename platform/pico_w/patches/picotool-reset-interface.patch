+static bool has_reset_interface(const struct libusb_config_descriptor *config) {
+    int i = 0;
+
+    if (config == NULL) {
+        return false;
+    }
+
+    for (i = 0; i < config->bNumInterfaces; i++) {
+        const struct libusb_interface_descriptor *alt = &config->interface[i].altsetting[0];
+        if ((alt->bInterfaceClass == LIBUSB_CLASS_VENDOR_SPEC) &&
+            (alt->bInterfaceSubClass == RESET_INTERFACE_SUBCLASS) &&
+            (alt->bInterfaceProtocol == RESET_INTERFACE_PROTOCOL)) {
+            return true;
+        }
+    }
 
+    return false;
+}
