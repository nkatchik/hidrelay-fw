{
    "inputs": [
        {
            "args": {
                "command": "find \"${workspaceFolder}/platform\" -mindepth 1 -maxdepth 1 -type d -exec basename {} \\; | LC_ALL=C sort",
                "description": "Select target platform",
                "rememberPrevious": true,
                "taskId": "appPlatform",
                "useSingleResult": true
            },
            "command": "shellCommand.execute",
            "id": "appPlatform",
            "type": "command"
        }
    ],
    "tasks": [
        {
            "command": "make distclean && make distclean && echo '✅ Full clean completed' || echo '❌ Clean failed'",
            "group": {
                "isDefault": false,
                "kind": "build"
            },
            "label": "🗑️ Clean (Full)",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "make clean && echo '✅ Cleaned build artifacts' || echo '❌ Clean failed'",
            "group": {
                "isDefault": false,
                "kind": "build"
            },
            "label": "🗑️ Clean",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "make build APP_PLATFORM=${input:appPlatform} && echo '✅ Build successful' || echo '❌ Build failed'",
            "group": {
                "isDefault": true,
                "kind": "build"
            },
            "label": "🛠️ Build",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "make build APP_PLATFORM=${input:appPlatform} APP_DEBUG_WIPE_ALL_ON_BOOT=1 tool-cache-probe tool-diag-capture && echo '✅ Build successful' || echo '❌ Build failed'",
            "group": {
                "isDefault": true,
                "kind": "build"
            },
            "label": "🛠️🐞 Build",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "make test-host && echo '✅ Tests clear' || echo '❌ Tests failed'",
            "group": {
                "isDefault": false,
                "kind": "test"
            },
            "label": "🧪 Test",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "flash",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "label": "⚡ Flash",
            "presentation": {
                "clear": true,
                "echo": false,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "type": "shell"
        }
    ],
    "version": "2.0.0"
}
