{
    "inputs": [
        {
            "args": {
                "command": "for platform_dir in \"${workspaceFolder}\"/platform/*; do if [ -d \"$platform_dir\" ] && [ -f \"$platform_dir/CMakeLists.txt\" ]; then basename \"$platform_dir\"; fi; done | LC_ALL=C sort",
                "description": "Select target platform",
                "taskId": "appPlatform",
                "useSingleResult": true
            },
            "command": "shellCommand.execute",
            "id": "appPlatform",
            "type": "command"
        },
        {
            "args": {
                "command": "if [ -d \"${workspaceFolder}/build\" ]; then find \"${workspaceFolder}/build\" -mindepth 1 -maxdepth 1 -type d ! -name tool -exec basename {} \\; | LC_ALL=C sort; fi",
                "description": "Select built target to flash",
                "taskId": "flashPlatform",
                "useSingleResult": true
            },
            "command": "shellCommand.execute",
            "id": "flashPlatform",
            "type": "command"
        }
    ],
    "tasks": [
        {
            "command": "make distclean && make distclean && echo '✅ Full clean completed' || echo '❌ Clean failed'",
            "group": {
                "isDefault": false,
                "kind": "build"
            },
            "label": "🗑️ Clean (Full)",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "make clean && echo '✅ Cleaned build artifacts' || echo '❌ Clean failed'",
            "group": {
                "isDefault": false,
                "kind": "build"
            },
            "label": "🗑️ Clean",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "make build APP_PLATFORM=${input:appPlatform} && echo '✅ Build successful' || echo '❌ Build failed'",
            "group": {
                "isDefault": true,
                "kind": "build"
            },
            "label": "🛠️ Build",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        // {
        //     "command": "make build APP_PLATFORM=${input:appPlatform} APP_DEBUG_WIPE_ALL_ON_BOOT=1 tool-cache-probe tool-diag-capture && echo '✅ Build successful' || echo '❌ Build failed'",
        //     "group": {
        //         "isDefault": true,
        //         "kind": "build"
        //     },
        //     "label": "🛠️🐞 Build",
        //     "presentation": {
        //         "clear": true,
        //         "echo": false,
        //         "showReuseMessage": false
        //     },
        //     "type": "shell"
        // },
        {
            "command": "make test-host && echo '✅ Tests clear' || echo '❌ Tests failed'",
            "group": {
                "isDefault": false,
                "kind": "test"
            },
            "label": "🧪 Test",
            "presentation": {
                "clear": true,
                "echo": false,
                "showReuseMessage": false
            },
            "type": "shell"
        },
        {
            "command": "flash \"${input:flashPlatform}\" && echo '✅ Flash successful' || echo '❌ Flash failed'",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "label": "⚡ Flash",
            "presentation": {
                "clear": true,
                "echo": false,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "type": "shell"
        }
    ],
    "version": "2.0.0"
}
