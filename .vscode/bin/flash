#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/../.." && pwd)"

if [[ $# -gt 1 ]]; then
    echo "Usage: flash [platform]" >&2
    exit 2
fi

infer_platform_from_uf2() {
    local uf2_path="$1"
    local rel_from_build="${uf2_path#${repo_root}/build/}"
    local after_platform
    local build_tree
    local cache_path
    local cache_platform=""
    local line

    if [[ "${rel_from_build}" == */platform/*/*.uf2 ]]; then
        after_platform="${rel_from_build#*/platform/}"
        if [[ "${after_platform}" == */* ]]; then
            printf '%s\n' "${after_platform%%/*}"
            return 0
        fi
    fi

    build_tree="${rel_from_build%%/*}"
    cache_path="${repo_root}/build/${build_tree}/CMakeCache.txt"
    if [[ -f "${cache_path}" ]]; then
        while IFS= read -r line; do
            case "${line}" in
                APP_PLATFORM:*=*)
                    cache_platform="${line#*=}"
                    ;;
            esac
        done < "${cache_path}"
    fi

    if [[ -n "${cache_platform}" ]]; then
        printf '%s\n' "${cache_platform}"
        return 0
    fi

    return 1
}

selected_uf2=""
if [[ $# -eq 1 ]]; then
    app_platform="$1"
    selected_target="requested platform: ${app_platform}"
else
    latest_uf2=""
    while IFS= read -r uf2_path; do
        if [[ -z "${latest_uf2}" || "${uf2_path}" -nt "${latest_uf2}" ]]; then
            latest_uf2="${uf2_path}"
        fi
    done < <(find "${repo_root}/build" -type f -name "*.uf2" 2>/dev/null)

    if [[ -z "${latest_uf2}" ]]; then
        echo "❌ No UF2 artifact found in build/. Run the build task first." >&2
        exit 1
    fi

    selected_uf2="${latest_uf2}"
    rel_from_build="${selected_uf2#${repo_root}/build/}"
    app_platform="$(infer_platform_from_uf2 "${selected_uf2}" || true)"

    if [[ -z "${app_platform}" ]]; then
        echo "❌ Could not infer platform from latest UF2 path: ${latest_uf2}" >&2
        exit 1
    fi

    selected_target="latest UF2: ${rel_from_build}"
fi

platform_flash_script="${repo_root}/platform/${app_platform}/bin/flash"
if [[ ! -x "${platform_flash_script}" ]]; then
    echo "❌ Missing platform flash script: platform/${app_platform}/bin/flash" >&2
    exit 1
fi

echo "Using ${selected_target}"
if [[ -n "${selected_uf2}" ]]; then
    "${platform_flash_script}" "${repo_root}" "${app_platform}" "${selected_uf2}"
else
    "${platform_flash_script}" "${repo_root}" "${app_platform}"
fi
