{
    "[c]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.cppStandard": "",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    // Fallback only for files missing from compile_commands.json.
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/build/*/generated/**",
        "${workspaceFolder}/include",
        "${workspaceFolder}/platform/*/include"
    ],
    "C_Cpp.files.exclude": {
        ".cache": true,
        "build": true
    },
    "C_Cpp.intelliSenseEngine": "default",
    "git.ignoredRepositories": [
        ".cache"
    ],
    "rust-analyzer.showDependenciesExplorer": false,
    "terminal.integrated.env.linux": {
        "PATH": "${workspaceFolder}/.vscode/bin:${env:PATH}"
    },
    "terminal.integrated.env.osx": {
        "PATH": "${workspaceFolder}/.vscode/bin:${env:PATH}"
    },
    "terminal.integrated.env.windows": {
        "Path": "${workspaceFolder}\\.vscode\\bin;${env:Path}"
    }
}
